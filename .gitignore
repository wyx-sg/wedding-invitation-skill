# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.bak

# Node
node_modules/
npm-debug.log*

# Author-side build artifacts (the build-thumbnails.js temp dir)
/tmp-thumbs/

# Fixture build artifacts (regenerated by `node scripts/build*.js`)
__test__/*/dist/
__test__/*/node_modules/
__test__/*/data/picker-state.json
__test__/*/data/tweak-state.json

# Claude Code superpowers workflow artifacts (plans, drafts, scratch).
# Plans are local Claude Code workflow files; they don't belong in the
# project repo or on GH Pages.
.superpowers/

# Release build output (regenerated by `node scripts/build-release.js`)
release/
